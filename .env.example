# Resend Email Service
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Contact Form Settings
# Admin email to receive contact inquiries
CONTACT_ADMIN_EMAIL=contact@company.co.uk

# Rate limiting (requests per hour per IP)
CONTACT_RATE_LIMIT=3
CONTACT_RATE_LIMIT_WINDOW_HOURS=1

# Email configuration
# Sender email (must be verified in Resend)
CONTACT_FROM_EMAIL=inquiries@company.co.uk
CONTACT_FROM_NAME=Company Name

# Expected response time (shown to user)
CONTACT_RESPONSE_TIME_HOURS=2

# Node environment
NODE_ENV=development

# Image optimization rollback switch (optional)
# Default behavior is optimized images. Set to true only for emergency rollback.
NEXT_IMAGE_UNOPTIMIZED=false

# Public site URL for metadata and canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Vercel KV / Upstash Redis integration (rate-limiter store)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Optional escape hatch for CI-only scenarios
# SKIP_ENV_VALIDATION=false
