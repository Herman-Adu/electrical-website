{
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "enabledMcpjsonServers": ["MCP_DOCKER", "filesystem", "git"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-start-v2.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"scripts/memory-lane-stop.mjs\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat \".claude/hooks/orchestrator-enforcement.txt\"",
            "timeout": 2,
            "displayResult": true
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/context-monitor.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/precompact-safety.sh\"",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
