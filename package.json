    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "docker:mcp:up": "docker compose up -d caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia youtube-transcript mcp-aggregator && pnpm docker:mcp:playwright:bootstrap",
    "docker:mcp:down": "docker compose stop caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia youtube-transcript mcp-aggregator",
    "docker:mcp:logs": "docker compose logs -f caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia youtube-transcript mcp-aggregator",
    "docker:mcp:ps": "docker compose ps caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia youtube-transcript mcp-aggregator",
    "docker:mcp:playwright:bootstrap": "node scripts/bootstrap-mcp-playwright.mjs",
    "docker:mcp:smoke": "node scripts/mcp-smoke.mjs",
    "docker:mcp:memory:call": "node scripts/mcp-memory-call.mjs",
    "docker:mcp:memory:search": "node scripts/mcp-memory-call.mjs search_nodes",
    "docker:mcp:memory:open": "node scripts/mcp-memory-call.mjs open_nodes",
    "docker:mcp:ready": "pnpm docker:mcp:up && pnpm docker:mcp:ps && pnpm docker:mcp:smoke",
    "orchestrator:bootstrap": "node scripts/orchestrator-bootstrap.sh",
    "orchestrator:bootstrap:win": "scripts\\orchestrator-bootstrap.bat",
    "orchestrator:bootstrap:skip-memory": "node scripts/orchestrator-bootstrap.sh --skip-memory",
    "migration:active:hydrate": "node scripts/migration-active-lanes-hydrate.mjs",
    "startup:new-chat": "pwsh scripts/new-chat-startup.ps1",
    "startup:new-chat:skip": "pwsh scripts/new-chat-startup.ps1 -SkipPreflight",
    "startup:new-chat:full": "pwsh scripts/new-chat-startup.ps1 -HydrateLanes",
    "startup:new-chat:refresh": "pwsh scripts/new-chat-startup.ps1 -SkipPreflight -SkipPlaywrightBootstrap",
    "sync:task-close": "pwsh scripts/task-close-sync.ps1",
    "orchestrator:task": "pwsh scripts/orchestrator-task.ps1",
    "lane:open": "node scripts/lane-lifecycle.mjs open",
    "lane:sync": "node scripts/lane-lifecycle.mjs sync",
    "lane:close": "node scripts/lane-lifecycle.mjs close",
    "lane:list": "node scripts/lane-lifecycle.mjs list",
    "validate:memory-lanes": "node scripts/validate-memory-lanes.mjs",
    "memory:status": "node scripts/memory-status.mjs",
    "memory:sync": "node scripts/memory-lane-stop.mjs --manual",
    "memory:rehydrate": "node scripts/memory-rehydrate.mjs --verbose",
    "memory:stale": "node scripts/memory-lane-staleness-check.mjs --dry-run",
    "memory:stale:apply": "node scripts/memory-lane-staleness-check.mjs",
    "lane:activate": "node scripts/memory-lane-activate.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs"
