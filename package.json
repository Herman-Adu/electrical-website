{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "status:context": "node scripts/check-context.mjs",
    "status:next-docs": "node scripts/locate-next-docs.mjs",
    "validate:wave2": "node scripts/validate-wave2.mjs",
