{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "status:context": "node scripts/check-context.mjs",
    "status:next-docs": "node scripts/locate-next-docs.mjs",
    "validate:wave2": "node scripts/validate-wave2.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "docker:build": "docker compose build web",
    "docker:up": "docker compose up -d web",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f web",
    "docker:start": "docker compose up --build web",
    "docker:redeploy": "docker compose up -d --build --force-recreate web",
    "docker:rebuild": "docker compose build --no-cache web && docker compose up -d --force-recreate web",
    "docker:mcp:up": "docker compose up -d caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia && pnpm docker:mcp:playwright:bootstrap",
    "docker:mcp:down": "docker compose stop caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia",
    "docker:mcp:logs": "docker compose logs -f caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia",
    "docker:mcp:ps": "docker compose ps caddy github-official openapi-schema playwright sequential-thinking memory-reference nextjs-devtools executor-playwright wikipedia",
    "docker:mcp:playwright:bootstrap": "node scripts/bootstrap-mcp-playwright.mjs",
    "docker:mcp:smoke": "node scripts/mcp-smoke.mjs",
    "docker:mcp:memory:call": "node scripts/mcp-memory-call.mjs",
    "docker:mcp:memory:search": "node scripts/mcp-memory-call.mjs search_nodes",
    "docker:mcp:memory:open": "node scripts/mcp-memory-call.mjs open_nodes",
    "docker:mcp:ready": "pnpm docker:mcp:up && pnpm docker:mcp:ps && pnpm docker:mcp:smoke",
    "migration:contact:ready": "pnpm docker:mcp:ready",
    "migration:contact:hydrate": "node scripts/migration-contact-hydrate.mjs",
    "migration:contact:hydrate:strict": "node scripts/migration-contact-hydrate.mjs --strict",
    "migration:quotation:ready": "pnpm docker:mcp:ready",
    "migration:quotation:hydrate": "node scripts/migration-quotation-hydrate.mjs",
    "migration:quotation:hydrate:strict": "node scripts/migration-quotation-hydrate.mjs --strict",
    "migration:service-request:ready": "pnpm docker:mcp:ready",
    "migration:service-request:hydrate": "node scripts/migration-service-request-hydrate.mjs",
    "migration:service-request:hydrate:strict": "node scripts/migration-service-request-hydrate.mjs --strict",
    "migration:all:hydrate:strict:session": "node scripts/migration-all-hydrate-strict-session.mjs",
    "migration:all:hydrate:strict:session:skip": "node scripts/migration-all-hydrate-strict-session.mjs --skip-preflight",
    "docker:dev": "docker compose -f docker-compose.dev.yml up web-dev",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml build web-dev",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down"
