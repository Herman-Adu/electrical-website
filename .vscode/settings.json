{
  "[playwright]": {
    "editor.defaultFormatter": "ms-playwright.playwright"
  },
  "playwright.reuseBrowser": false,
  "playwright.showBrowser": true,
  "playwright.launchOptions": {
    "headless": false
  },
  "playwright.env": {
    "PLAYWRIGHT_REUSE_SERVER": "true"
  },
  "files.exclude": {
    ".playwright": true,
    "playwright-report": true
  }
}
